# 小红书工具箱 — 环境配置模板
# 复制此文件为 .env 并填入你的配置

# ══════════════════════════════════════════
#  小红书 Cookie（必需）
# ══════════════════════════════════════════
# 获取方法：
# 1. 登录 https://www.xiaohongshu.com
# 2. F12 打开开发者工具 → Network
# 3. 刷新页面，复制任意 xiaohongshu.com 请求的 Cookie 值
# 4. 粘贴到下面（整个 Cookie 一行）

COOKIES=your_cookie_here

# ══════════════════════════════════════════
#  LLM API 配置（可选，用于文案改写）
# ══════════════════════════════════════════
# 支持 OpenAI 兼容接口（如 MiniMax、DeepSeek 等）

LLM_API_KEY=your_api_key_here
LLM_API_BASE=https://api.minimaxi.com/v1
