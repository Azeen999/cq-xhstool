# ══════════════════════════════════════════
#  小红书工具箱 — 环境配置
#  复制此文件为 .env 并填入你的配置
# ══════════════════════════════════════════

# ── 小红书 Cookie（必需）──
# 获取方法：
#   1. 用 Chrome/Edge 打开 https://www.xiaohongshu.com 并登录
#   2. 按 F12 打开开发者工具
#   3. 切换到 Network（网络）标签
#   4. 刷新页面
#   5. 点击任意一个 xiaohongshu.com 的请求
#   6. 在 Request Headers 中找到 Cookie，复制整个值
#   7. 粘贴到下面 COOKIES= 后面
#
# ⚠️ Cookie 有效期约 1-7 天，过期后需重新获取
COOKIES=your_cookie_here
